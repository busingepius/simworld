# Database
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/simworld
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=testpassword

# Cache / Queue
REDIS_URL=redis://localhost:6379/0

# LLM (OpenAI-compatible)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o

# Agent memory
ZEP_API_KEY=

# Auth
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Storage (for seed material files)
STORAGE_BACKEND=local # local | s3
STORAGE_PATH=./uploads # if local
AWS_BUCKET= # if s3
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Cost controls
MAX_LLM_CALLS_PER_RUN=10000
MAX_AGENTS_STARTER=1000
MAX_AGENTS_PRO=100000
MAX_AGENTS_ENTERPRISE=1000000